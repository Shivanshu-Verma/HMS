# Django secret key — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas connection URIs — get from Atlas > Connect > Drivers
# Both databases must be on the same cluster for cross-database transactions
MONGODB_ARCHIVE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hms_archive?retryWrites=true&w=majority
MONGODB_ACTIVE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hms_active?retryWrites=true&w=majority

# Database names (must match the database in the URI)
MONGODB_ARCHIVE_DB=hms_archive
MONGODB_ACTIVE_DB=hms_active

# Comma-separated list of allowed CORS origins (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# JWT settings
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_COOKIE_NAME=hms_access_token
JWT_REFRESH_COOKIE_NAME=hms_refresh_token
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_DOMAIN=
CSRF_COOKIE_SECURE=False

# Default hospital ID (ObjectId string) — used as partition key for multi-tenancy readiness
DEFAULT_HOSPITAL_ID=000000000000000000000001

# Fingerprint template encryption key
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINGERPRINT_TEMPLATE_ENCRYPTION_KEY=your-fernet-key-here
FINGERPRINT_TEMPLATE_KEY_VERSION=fernet-v1
